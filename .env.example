# Copier en .env et remplir. NE JAMAIS committer .env.

# Clé secrète Stripe (mode test: sk_test_..., live: sk_live_...)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Secret de signature du webhook (Dashboard > Developers > Webhooks, ou `stripe listen`)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ID du prix récurrent 15€/mois (Dashboard > Products)
STRIPE_PRICE_ID=price_REPLACE_ME

# URL publique du backend (sert pour success/cancel/return Stripe)
PUBLIC_URL=http://localhost:4242

# Port d'écoute
PORT=4242
